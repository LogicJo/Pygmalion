{
	"schemaVersion": 1,
	"id": "pygmalion",
	"version": "${version}",
	"name": "Pygmalion",
	"description": "TPygmalion is a lighweight and flexible Minecraft modification that introduces controllable bots into Minecraft.",
	"authors": [
		"LogicJo / Shadow_Shardx"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/pygmalion/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.logicjo.pygmalion.Pygmalion"
		],
		"client": [
			"com.logicjo.pygmalion.PygmalionClient"
		],
		"fabric-datagen": [
			"com.logicjo.pygmalion.PygmalionDataGenerator"
		]
	},
	"mixins": [
		"pygmalion.mixins.json",
		{
			"config": "pygmalion.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}